function copy() {
    local data
    if [ -t 0 ]; then
        # 引数がある場合
        data="$*"
    else
        # パイプ入力がある場合
        data="$(cat)"
    fi
    printf '\033]52;;%s\033\\' "$(printf '%s' "$data" | base64 -w0)"
}

alias pyank='pwd | copy'


function y() {
	local tmp="$(mktemp -t "yazi-cwd.XXXXXX")" cwd
	yazi "$@" --cwd-file="$tmp"
	if cwd="$(command cat -- "$tmp")" && [ -n "$cwd" ] && [ "$cwd" != "$PWD" ]; then
		builtin cd -- "$cwd"
	fi
	rm -f -- "$tmp"
}

svgcat() {
  if [ -z "$1" ]; then
    echo "Usage: svgcat <svg_filepath> [wezterm imgcat options]"
    return 1
  fi
  local svg_filepath="$1"
  if [ ! -f "$svg_filepath" ]; then
    echo "Error: File not found: $svg_filepath"
    return 1
  fi
  magick -background None "$svg_filepath" png:- | wezterm imgcat "${@:2}"
}

