function nvim() {
  export XDG_CACHE_HOME=/tmp/nvim/cache
  export XDG_DATA_HOME=/tmp/nvim/data
  mkdir -p $XDG_CACHE_HOME $XDG_DATA_HOME
  command nvim "$@"
}

